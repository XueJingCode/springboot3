<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC
        "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.alan.hrsys.dao.EmployeeDao">

    <!-- 查询所有员工（关联部门） -->
    <select id="search" resultMap="EmpAndDep">
        select e.*,d.name as depName from
            employee as e left join department as d on
                e.dep_id=d.id order by e.id
    </select>

    <!-- 根据ID查询员工（关联部门） -->
    <select id="searchById" resultMap="EmpAndDep">
        select e.*,d.name as depName,d.number as depNumber from
            employee as e left join department as d on e.dep_id=d.id where
            e.id=#{id}
    </select>

    <!-- 结果映射：员工与部门关联 -->
    <resultMap type="com.alan.hrsys.entity.Employee" id="EmpAndDep">
        <id property="id" column="id" />
        <result property="number" column="number" />
        <result property="name" column="name" />
        <result property="gender" column="gender" />
        <result property="age" column="age" />
        <!-- 关联部门信息 -->
        <association property="dep" javaType="com.alan.hrsys.entity.Department">
            <id property="id" column="dep_id" />
            <result property="number" column="depNumber" />
            <result property="name" column="depName" />
        </association>
    </resultMap>

    <!-- 新增员工 -->
    <insert id="add">
        insert into employee (number,name,gender,age,dep_id) values
            #{number},#{name},#{gender},#{age},#{dep.id}
    </insert>

    <!-- 更新员工 -->
    <update id="update">
        update employee set number=#{number},name=#{name},
                            gender=#{gender},age=#{age},dep_id=#{dep.id} where id=#{id}
    </update>

    <!-- 删除员工 -->
    <delete id="delete">
        delete from employee where id=#{id}
    </delete>

    <!-- 根据部门ID更新员工（部门ID置空） -->
    <update id="updateByDep">
        update employee set dep_id=null where dep_id=#{depId}
    </update>

</mapper>
